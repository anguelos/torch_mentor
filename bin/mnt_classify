#!/usr/bin/env python3

from copy import copy
import fargv
import torch
import torchvision
import glob
import tqdm
from PIL import Image
import numpy as np
#from types import SimpleNamespace
#t_args = Union[SimpleNamespace, dict]
from mentor import resume_classification, FolderClassificationDs, current_epoch, iterate_classification_epoch, TwoClassEvaluator, save

default_transform = torchvision.transforms.Compose([
        torchvision.transforms.transforms.Resize(512), 
        torchvision.transforms.ToTensor(), 
        torchvision.transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])])



if __name__=="__main__":
    p = {
            "v":1, # verbocity
            "class_names": "nonpapal,papal",
            "input_size": "512",
            "arch":("resnet50","mobilenetv3","resnet18"),
            "pretrained": True,
            "freeze_all_before":0,
            "label":"exper",
            "validate_freq": 1,
            "save_freq": 1,
            "num_workers": 0,
            "resume_path":"./models/{arch}_{label}.pt",
            "device":"cuda",
            "images":set([])
    }

    args, _ = fargv.fargv(p)
    args.n_classes = len(args.class_names.split(","))
    net = resume_classification(args.resume_path, args=args)
    class_names=np.array(args.class_names.split(","))
    for file in args.images:
        input_sample_tensor = default_transform(Image.open(file))
        with torch.no_grad():
            input_batch_tensor = input_sample_tensor[None,:,:,:].to(args.device)
            outputs = net(input_batch_tensor)
            _, amax = outputs.max(dim=1)
            print(class_names[amax.cpu().numpy()])

        